      "source": [
        "import os\n",
        "import json\n",
        "from docling.document_converter import DocumentConverter\n",
        "from google import genai\n",
        "\n",
        "# ==========================================\n",
        "# 1. INITIALIZE CLIENT\n",
        "# ==========================================\n",
        "# Uses GOOGLE_API_KEY from environment (or .env)\n",
        "client = genai.Client()\n",
        "\n",
        "def process_layered_robotic_assembly(file_path):\n",
        "    # STEP 1: Get the strict text/inventory from Docling\n",
        "    print(f\"--- 1. Extracting strict inventory via Docling ---\")\n",
        "    converter = DocumentConverter()\n",
        "    conversion_result = converter.convert(file_path)\n",
        "    document_markdown = conversion_result.document.export_to_markdown()\n",
        "\n",
        "    # STEP 2: Upload the PDF so Gemini can visually see the layout grid\n",
        "    print(f\"--- 2. Uploading {file_path} to Gemini Vision ---\")\n",
        "    uploaded_pdf = client.files.upload(file=file_path)\n",
        "\n",
        "    # STEP 3: The Layer-by-Layer Prompt\n",
        "    print(\"--- 3. Generating Layer-by-Layer Sequence... ---\")\n",
        "    combined_prompt = f\"\"\"\n",
        "    You are an expert robotics control engineer. You are provided with a visual PDF and its Docling-extracted Markdown text.\n",
        "    \n",
        "    CRITICAL INSTRUCTION 1 - INVENTORY CHECKSUM:\n",
        "    Read the 'Stückliste' (Parts List) from the Markdown text. The exact 'Stück' (quantity) listed for every 'Artikel-Nr' MUST be used in your sequence. Do not leave any parts behind.\n",
        "    \n",
        "    CRITICAL INSTRUCTION 2 - LAYERED ASSEMBLY LOGIC (ROW-BY-ROW):\n",
        "    Look visually at the 'Stationsbelegung' matrix in the PDF. The ROWS represent the chronological phases (layers) of assembly. Do NOT build this station-by-station.\n",
        "    \n",
        "    You must trace the visual grid from the TOP row to the BOTTOM row:\n",
        "    - Phase 1 (Row 1): Identify the part. Find every column (D-Seite, Station 1-16, U-Seite) with an 'X' or mark. Generate a step for each.\n",
        "    - Phase 2 (Row 2): Repeat for the next part down the list.\n",
        "    - Continue row-by-row. This naturally results in placing all base plates across the manifold in one phase, then placing specific valves in a later phase, etc.\n",
        "    \n",
        "    Output ONLY a strict JSON array of objects. No conversational text.\n",
        "    \n",
        "    Format Example:\n",
        "    [\n",
        "      {{\n",
        "        \"PHASE\": 1,\n",
        "        \"PART_ID\": \"SY30M-1-1A-C8\",\n",
        "        \"ACTION\": \"PICK_AND_PLACE\",\n",
        "        \"TARGET_LOCATION\": \"D-Seite\",\n",
        "        \"TOOL\": \"GRIPPER\"\n",
        "      }},\n",
        "      {{\n",
        "        \"PHASE\": 6,\n",
        "        \"PART_ID\": \"SY30M-2-1DA-C6\",\n",
        "        \"ACTION\": \"PICK_AND_PLACE\",\n",
        "        \"TARGET_LOCATION\": \"Station 1\",\n",
        "        \"TOOL\": \"GRIPPER\"\n",
        "      }},\n",
        "      {{\n",
        "        \"PHASE\": 6,\n",
        "        \"PART_ID\": \"SY30M-2-1DA-C6\",\n",
        "        \"ACTION\": \"PICK_AND_PLACE\",\n",
        "        \"TARGET_LOCATION\": \"Station 2\",\n",
        "        \"TOOL\": \"GRIPPER\"\n",
        "      }}\n",
        "    ]\n",
        "    \n",
        "    Docling Text Reference:\n",
        "    {document_markdown}\n",
        "    \"\"\"\n",
        "    \n",
        "    # We pass BOTH the visual PDF and the Docling text to Gemini 2.5 Flash\n",
        "    response = client.models.generate_content(\n",
        "        model=\"gemini-2.5-flash\", \n",
        "        contents=[uploaded_pdf, combined_prompt]\n",
        "    )\n",
        "    full_text = response.text\n",
        "\n",
        "    # STEP 4: Parse the JSON Output\n",
        "    try:\n",
        "        json_part = full_text.split(\"```json\")[1].split(\"```\")[0].strip()\n",
        "        robot_sequence = json.loads(json_part)\n",
        "    except Exception as e:\n",
        "        robot_sequence = {\"error\": \"JSON extraction failed.\", \"raw\": full_text}\n",
        "\n",
        "    return robot_sequence\n",
        "\n",
        "# ==========================================\n",
        "# EXECUTE WORKFLOW\n",
        "# ==========================================\n",
        "if __name__ == \"__main__\":\n",
        "    pdf_path = \"assembly_instruction.pdf\"\n",
        "    \n",
        "    if os.path.exists(pdf_path):\n",
        "        results = process_layered_robotic_assembly(pdf_path)\n",
        "        \n",
        "        print(\"\\n\" + \"=\"*60)\n",
        "        print(\"--- LAYERED ROBOTIC SEQUENCE ---\")\n",
        "        print(\"=\"*60)\n",
        "        if isinstance(results, list):\n",
        "             print(json.dumps(results, indent=2, ensure_ascii=False))\n",
        "             \n",
        "             with open(\"layered_robot_sequence.json\", \"w\", encoding=\"utf-8\") as f:\n",
        "                 json.dump(results, f, indent=2, ensure_ascii=False)\n",
        "             print(\"\\n✅ Sequence successfully saved to 'layered_robot_sequence.json'\")\n",
        "        else:\n",
        "             print(results)\n",
        "    else:\n",
        "        print(f\"File {pdf_path} not found.\")"
      ]
    }
  ],
