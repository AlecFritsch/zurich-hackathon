# Havoc Backend — copy to .env and fill in
# Required
GOOGLE_API_KEY=your_gemini_api_key

# Optional — defaults shown
ENV=development
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=*

# Production: restrict CORS, e.g.
# ENV=production
# CORS_ORIGINS=https://your-frontend.com,https://app.your-frontend.com

# Camera
CAMERA_DEVICE_ID=0

# Assembly (PDF → Docling + Gemini)
GEMINI_ASSEMBLY_MODEL=gemini-3-flash-preview

# Robot (lerobot_remote | dobot)
ROBOT_TYPE=lerobot_remote
LEROBOT_BRIDGE_URL=http://localhost:9000

# Storage
SQLITE_PATH=events.db
